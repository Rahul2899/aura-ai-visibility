# Copy this to .env and fill in your real values
# NEVER commit .env — it is gitignored

# OpenRouter (optional — only needed if you add models to DEFAULT_MODELS in src/llm/client.py)
# OPENROUTER_API_KEY=sk-or-...

# AWS Bedrock (enable models in us-east-1 console first)
# IMPORTANT: On EC2, use an IAM instance role instead of static keys.
# Remove these two lines and attach a BedrockFullAccess role to your EC2 instance.
# Boto3 will automatically use instance metadata credentials.
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://peec:peec@localhost:5432/peec

# Admin key — REQUIRED. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Without this set, the admin password defaults to "admin123" which is publicly known.
ADMIN_KEY=change-this-to-a-strong-random-value

# Comma-separated list of allowed frontend origins (for CORS)
# On EC2: set to http://YOUR_ELASTIC_IP or https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000
