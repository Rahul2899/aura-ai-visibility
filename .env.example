# Copy this to .env and fill in your real values
# NEVER commit .env — it is gitignored

# OpenRouter (free models: meta-llama/llama-3.3-70b-instruct:free, etc.)
OPENROUTER_API_KEY=sk-or-...

# AWS Bedrock (enable models in us-east-1 console first)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://peec:peec@localhost:5432/peec
