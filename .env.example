# Copy this to .env and fill in your real values
# NEVER commit .env — it is gitignored

# Tavily Search (optional — enriches probe generation with live web context)
# Free tier: 1000 searches/month. Get key at https://tavily.com
# TAVILY_API_KEY=tvly-your-key-here

# OpenRouter (optional — only needed if you add models to DEFAULT_MODELS in src/llm/client.py)
# OPENROUTER_API_KEY=sk-or-...

# AWS Bedrock — enable the required models in your AWS console first
# On EC2: attach a Bedrock-enabled IAM role and remove the keys below (boto3 uses instance metadata)
# Locally: set your AWS credentials here
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=your-aws-region

# PostgreSQL credentials — change POSTGRES_PASSWORD in production
POSTGRES_USER=peec
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=peec

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://peec:peec@localhost:5432/peec

# Admin key — REQUIRED for API admin access. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_KEY=your-strong-random-secret-here

# Auto-run audits for example brands on first boot so a fresh deploy isn't empty.
# Runs in the background (non-blocking) and only if AWS creds are present.
# Set to "false" to disable (e.g. to avoid Bedrock costs on every fresh DB).
AUTO_SEED_AUDITS=true

# Comma-separated list of allowed frontend origins (for CORS)
# On EC2: set to http://YOUR_ELASTIC_IP or https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# Frontend API base URL (use /api behind nginx in production; http://localhost:8000 for local dev)
NEXT_PUBLIC_API_URL=http://localhost:8000
